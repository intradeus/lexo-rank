{
  "name": "@intradeus/lexo-rank",
  "version": "0.1.0",
  "description": "A flexible LexoRank implementation with simple, bucket and decimal variants",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build && npm run smoke",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/intradeus/lexo-rank.git"
  },
  "homepage": "https://github.com/intradeus/lexo-rank#readme",
  "bugs": {
    "url": "https://github.com/intradeus/lexo-rank/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "lexorank",
    "lexo-rank",
    "ranking",
    "ordering",
    "sort",
    "jira",
    "bucket",
    "decimal"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.2.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.8.3",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^1.2.2"
  },
  "engines": {
    "node": ">=18"
  }
}
